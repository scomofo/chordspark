{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-docs/main/tooling/bundler/schema.json",
  "productName": "ChordSpark",
  "version": "3.1.0",
  "identifier": "com.chordspark.app",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "title": "ChordSpark",
    "windows": [
      {
        "title": "ChordSpark",
        "width": 500,
        "height": 850,
        "minWidth": 400,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
